    "# General Quadrature operator\n",
    "theta=np.pi\n",
    "N = 20\n",
    "genQuad=1/np.sqrt(2)*(qt.create(N=N)*np.exp(-theta*1j)+qt.create(N=N).dag()*np.exp(theta*1j))\n"
   ]
